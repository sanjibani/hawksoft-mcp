# HawkSoft credentials — used by the MCP server at startup.
# Get these from the HawkSoft License Management Portal after your app is approved.
HAWKSOFT_USERNAME=your-vendor-username
HAWKSOFT_PASSWORD=your-vendor-password

# Optional overrides (most users won't need these).
# HAWKSOFT_BASE_URL=https://integration.hawksoft.app
# HAWKSOFT_TIMEOUT=30